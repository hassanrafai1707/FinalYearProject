# ============================================
# OS and IDE files (keep these)
# ============================================
**/.DS_Store
**/.classpath
**/.factorypath
**/.git
**/.idea
**/.project
**/.sts4-cache
**/.settings
**/.toolstarget
**/.vs
**/.vscode
**/.next
**/.cache
**/*.dbmdl
**/*.jfm
**/charts
**/secrets.dev.yaml
**/values.dev.yaml
**/vendor

# ============================================
# Build artifacts (keep these)
# ============================================
**/*.class
**/*.iml
**/*.ipr
**/*.iws
**/*.log
**/.apt_generated
**/.gradle
**/.gradletasknamecache
**/.nb-gradle
**/.springBeans
**/build
**/dist
**/gradle-app.setting
**/nbbuild
**/nbdist
**/nbproject/private
**/target
*.ctxt
.mtj.tmp
.mvn/timing.properties
buildNumber.properties
dependency-reduced-pom.xml
hs_err_pid*
pom.xml.next
pom.xml.releaseBackup
pom.xml.tag
pom.xml.versionsBackup
release.properties
replay_pid*

# ============================================
# Documentation and misc (keep these)
# ============================================
LICENSE
README.md

# ============================================
# Environment files (keep these - important!)
# ============================================
**/.env
.env

# ============================================
# Files that should NOT be ignored:
# ============================================
# !**/Dockerfile*     ← DON'T ignore Dockerfiles
# !**/docker-compose* ← DON'T ignore compose files
# !.dockerignore      ← DON'T ignore .dockerignore itself